{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Dev Server - تشغيل التطوير",
      "request": "launch",
      "type": "node",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "presentation": {
        "group": "ASOL",
        "order": 1
      }
    },
    {
      "name": "Build - إنتاج كامل",
      "request": "launch",
      "type": "node",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "build"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "presentation": {
        "group": "ASOL",
        "order": 2
      }
    },
    {
