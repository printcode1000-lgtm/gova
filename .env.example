# Turso runtime credentials (server-only) — users database (allusers.db)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Turso runtime credentials (server-only) — profile database (profile.db)
TURSO_PROFILE_DATABASE_URL=
TURSO_PROFILE_AUTH_TOKEN=
TURSO_PRODUCT_DATABASE_URL=
TURSO_PRODUCT_AUTH_TOKEN=

# Turso runtime credentials — advertisements database (advertisements.db)
# Optional: leave empty to reuse TURSO_DATABASE_URL / TURSO_AUTH_TOKEN.
TURSO_ADVERTISEMENTS_DATABASE_URL=
TURSO_ADVERTISEMENTS_AUTH_TOKEN=

# Turso Platform API (provisioning/build scripts only — never in browser)
TURSO_API_TOKEN=
TURSO_ORGANIZATION=

# ASOL API base URL — where the ASOL backend is hosted.
# Leave empty when frontend and API share the same origin (local dev, co-hosted deploy).
# Required for static export and Capacitor (e.g. https://api.example.com).
NEXT_PUBLIC_ASOL_API_BASE_URL=

# Capacitor live reload — optional. Point to Next.js dev server (LAN IP).
# Example: http://192.168.1.10:3000  Leave unset for production (bundled out/).
CAPACITOR_SERVER_URL=

# Capacitor API backend override (optional). npm run cap:build defaults to platform/capacitor.defaults.ts.
ASOL_CAPACITOR_API_BASE_URL=

# Static preview API proxy override (optional). npm run preview:static defaults to the same Vercel backend.
ASOL_STATIC_PREVIEW_API_BASE_URL=

# Comma-separated allowed origins for ASOL API CORS (server-side)
ASOL_CORS_ORIGINS=

# App Mode: 'development' | 'production' | 'static'
ASOL_MODE=development

# Password recovery mail (server-only). Use a Google App Password, never the account password.
PASSWORD_RECOVERY_GMAIL_USER=suezbazaar@gmail.com
PASSWORD_RECOVERY_GMAIL_APP_PASSWORD=
PASSWORD_RECOVERY_SIGNING_SECRET=

# ── Firebase Cloud Messaging / Android ──
# Lossless replacements for the deleted Firebase JSON files.
FIREBASE_ADMIN_SERVICE_ACCOUNT_BASE64=
FIREBASE_ANDROID_GOOGLE_SERVICES_BASE64=
# Explicit identity values validated before every Capacitor sync.
FIREBASE_PROJECT_NAME=asole
FIREBASE_PROJECT_ID=asole-73f1f
FIREBASE_PROJECT_NUMBER=543298343631
FIREBASE_FCM_SENDER_ID=543298343631
FIREBASE_ANDROID_APP_ID=1:543298343631:android:01192cf95a765130609dba
FIREBASE_ANDROID_APP_NICKNAME=ASOL Android
FIREBASE_ANDROID_PACKAGE_NAME=hgh.asol.app
FIREBASE_STORAGE_BUCKET=asole-73f1f.firebasestorage.app
FIREBASE_ANDROID_API_KEY=AIzaSyDyr_MrGZIJEW_eW7VSl8LzwmlVg8MjquI
FIREBASE_ANDROID_SHA1=fe:85:eb:f4:8c:51:a3:50:23:49:c2:b1:f5:56:ff:e6:30:4d:c0:88
FIREBASE_ANDROID_SHA256=63:66:4d:27:20:33:d0:04:d1:cb:11:63:23:ef:af:96:56:ff:9e:6d:c6:6d:62:40:28:0d:67:4b:1e:a0:41:30
FIREBASE_ANDROID_CONFIGURATION_VERSION=1
FIREBASE_ANDROID_OAUTH_CLIENT_IDS=[]
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-fbsvc@asole-73f1f.iam.gserviceaccount.com
FIREBASE_ADMIN_CLIENT_ID=106226929145033474514
ASOL_NOTIFICATION_INTERNAL_SECRET=

# Asset base path for subdirectory deploys (GitHub Pages: /asol). Leave empty for Vercel/root hosting.
ASOL_BASE_PATH=

# ── Cloudflare R2 (server-only secrets) ──
R2_ACCOUNT_ID=
R2_API_TOKEN=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=asol-storage
R2_ENDPOINT=
R2_LOCATION=WEUR
R2_JURISDICTION=default
R2_PUBLIC_URL=
R2_CATALOG_URI=
R2_WAREHOUSE_NAME=

# R2 public URL for client-side asset links (safe to expose)
NEXT_PUBLIC_R2_PUBLIC_URL=

# ── OTA web bundle updates ──
# Optional dedicated R2 bucket. Falls back to the regular R2 values when empty.
ASOL_OTA_R2_BUCKET_NAME=
ASOL_OTA_R2_PUBLIC_URL=
ASOL_OTA_R2_ENDPOINT=
ASOL_OTA_R2_ACCESS_KEY_ID=
ASOL_OTA_R2_SECRET_ACCESS_KEY=
ASOL_OTA_R2_PREFIX=app-updates

# Native shell and bundled web versions. ota:publish sets the web version automatically.
ASOL_NATIVE_VERSION=1.0.0
ASOL_WEB_BUNDLE_VERSION=0.1.0

# OTA manifest and verification public values (safe to expose to clients).
NEXT_PUBLIC_ASOL_OTA_MANIFEST_URL=
NEXT_PUBLIC_ASOL_OTA_PUBLIC_KEY=
ASOL_OTA_PUBLIC_KEY=

# CI alternative to .ota/private-key.pem. Preserve PEM newlines as \\n when needed.
ASOL_OTA_SIGNING_PRIVATE_KEY=
MARKETPLACE_ORDERS_DATABASE_URL=
MARKETPLACE_ORDERS_DATABASE_AUTH_TOKEN=
# Optional development override; defaults to public/sync_data/sync_sqlite/marketplace_orders.db
MARKETPLACE_ORDERS_SQLITE_PATH=
