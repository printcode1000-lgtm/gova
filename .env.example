# Turso runtime credentials (server-only)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Turso Platform API (provisioning/build scripts only — never in browser)
TURSO_API_TOKEN=
TURSO_ORGANIZATION=

# GOVA API base URL — where the GOVA backend is hosted.
# Leave empty when frontend and API share the same origin (local dev, co-hosted deploy).
# Required for static export and Capacitor (e.g. https://api.example.com).
NEXT_PUBLIC_GOVA_API_BASE_URL=

# Comma-separated allowed origins for GOVA API CORS (server-side)
GOVA_CORS_ORIGINS=

# App Mode: 'development' | 'production' | 'static'
GOVA_MODE=development
